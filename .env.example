# ==============================================================================
# DevTrack Environment Configuration
# ==============================================================================

# Application Base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# Production Configurable Rate Limiting (Requests Per Minute)
# ==============================================================================
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_PUBLIC_PER_MINUTE=60
RATE_LIMIT_AUTHENTICATED_PER_MINUTE=200

# ==============================================================================
# GitHub REST & GraphQL API Integration
# Optional: Add a Personal Access Token to expand rate limits from 60 to 5,000 req/hr
# ==============================================================================
GITHUB_TOKEN=your_github_personal_access_token_here

# ==============================================================================
# Firebase Client Authentication
# ==============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
